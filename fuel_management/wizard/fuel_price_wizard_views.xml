<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_fuel_price_wizard_form" model="ir.ui.view">
        <field name="name">fuel.price.wizard.form</field>
        <field name="model">fuel.price.wizard</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <h2>Update Fuel Price</h2>
                    <group>
                        <field name="product_id"/>
                        <field name="new_price"/>
                        <field name="station_ids" widget="many2many_tags"
                            placeholder="Leave empty for all stations"/>
                        <field name="nozzle_count" readonly="1" string="Nozzles to Update"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_apply" string="Apply Price" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_fuel_price_wizard" model="ir.actions.act_window">
        <field name="name">Update Fuel Price</field>
        <field name="res_model">fuel.price.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
