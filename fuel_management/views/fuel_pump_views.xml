<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_fuel_pump_form" model="ir.ui.view">
        <field name="name">fuel.pump.form</field>
        <field name="model">fuel.pump</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" type="object" name="action_view_nozzles" icon="fa-plug">
                            <field name="nozzle_count" widget="statinfo" string="Nozzles"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Pump Name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="station_id"/>
                            <field name="state"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Nozzles">
                            <field name="nozzle_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="product_id"/>
                                    <field name="current_price"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_fuel_pump_list" model="ir.ui.view">
        <field name="name">fuel.pump.list</field>
        <field name="model">fuel.pump</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="code"/>
                <field name="station_id"/>
                <field name="nozzle_count" string="Nozzles"/>
                <field name="state" widget="badge"
                    decoration-success="state == 'active'"
                    decoration-warning="state == 'maintenance'"
                    decoration-muted="state == 'inactive'"/>
            </list>
        </field>
    </record>

    <record id="action_fuel_pump" model="ir.actions.act_window">
        <field name="name">Pumps</field>
        <field name="res_model">fuel.pump</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Add your first pump</p>
        </field>
    </record>

</odoo>
