<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Station Form -->
    <record id="view_fuel_station_form" model="ir.ui.view">
        <field name="name">fuel.station.form</field>
        <field name="model">fuel.station</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" type="object" name="action_view_pumps" icon="fa-tachometer">
                            <field name="pump_count" widget="statinfo" string="Pumps"/>
                        </button>
                        <button class="oe_stat_button" type="object" name="action_view_tanks" icon="fa-database">
                            <field name="tank_count" widget="statinfo" string="Tanks"/>
                        </button>
                        <button class="oe_stat_button" type="object" name="action_view_licenses" icon="fa-certificate">
                            <field name="license_count" widget="statinfo" string="Licenses"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Station Name"/></h1>
                        <h2><field name="code" placeholder="Code"/></h2>
                    </div>
                    <group>
                        <group string="General">
                            <field name="manager_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="phone"/>
                            <field name="email" widget="email"/>
                        </group>
                        <group string="Address">
                            <field name="street"/>
                            <field name="city"/>
                            <field name="state_id"/>
                            <field name="country_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Pumps" name="pumps">
                            <field name="pump_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="code"/>
                                    <field name="nozzle_count" string="Nozzles"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>
                        <page string="Tanks" name="tanks">
                            <field name="tank_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="product_id"/>
                                    <field name="capacity"/>
                                    <field name="current_stock"/>
                                    <field name="state" widget="badge"
                                        decoration-success="state == 'normal'"
                                        decoration-warning="state == 'low'"
                                        decoration-danger="state in ('critical','empty')"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notes" name="notes">
                            <field name="notes" placeholder="Internal notes..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Station List -->
    <record id="view_fuel_station_list" model="ir.ui.view">
        <field name="name">fuel.station.list</field>
        <field name="model">fuel.station</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="code"/>
                <field name="city"/>
                <field name="manager_id"/>
                <field name="pump_count" string="Pumps"/>
                <field name="tank_count" string="Tanks"/>
                <field name="state" widget="badge"
                    decoration-success="state == 'active'"
                    decoration-warning="state == 'maintenance'"
                    decoration-muted="state == 'inactive'"/>
            </list>
        </field>
    </record>

    <!-- Station Search -->
    <record id="view_fuel_station_search" model="ir.ui.view">
        <field name="name">fuel.station.search</field>
        <field name="model">fuel.station</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="code"/>
                <field name="city"/>
                <field name="manager_id"/>
                <filter string="Active" name="active" domain="[('state','=','active')]"/>
                <filter string="Under Maintenance" name="maintenance" domain="[('state','=','maintenance')]"/>
                <group>
                    <filter string="City" name="group_city" context="{'group_by': 'city'}"/>
                    <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Station Action -->
    <record id="action_fuel_station" model="ir.actions.act_window">
        <field name="name">Stations</field>
        <field name="res_model">fuel.station</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_fuel_station_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create your first fuel station</p>
        </field>
    </record>

</odoo>
