<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_fuel_meter_reading_list" model="ir.ui.view">
        <field name="name">fuel.meter.reading.list</field>
        <field name="model">fuel.meter.reading</field>
        <field name="arch" type="xml">
            <list>
                <field name="shift_id"/>
                <field name="station_id"/>
                <field name="pump_id"/>
                <field name="nozzle_id"/>
                <field name="product_id"/>
                <field name="opening_reading"/>
                <field name="closing_reading"/>
                <field name="dispensed_qty"/>
                <field name="unit_price"/>
                <field name="total_amount"/>
            </list>
        </field>
    </record>

    <record id="action_fuel_meter_reading" model="ir.actions.act_window">
        <field name="name">Meter Readings</field>
        <field name="res_model">fuel.meter.reading</field>
        <field name="view_mode">list</field>
    </record>

</odoo>
