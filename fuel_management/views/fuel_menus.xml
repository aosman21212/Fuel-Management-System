<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Main Menu -->
    <menuitem id="menu_fuel_main"
        name="Fuel Management"
        sequence="80"
        web_icon="fuel_management,static/description/icon.png"/>

    <!-- Stations &amp; Equipment -->
    <menuitem id="menu_fuel_stations"
        name="Stations &amp; Equipment"
        parent="menu_fuel_main"
        sequence="10"/>

    <menuitem id="menu_fuel_station"
        name="Stations"
        parent="menu_fuel_stations"
        action="action_fuel_station"
        sequence="10"/>

    <menuitem id="menu_fuel_pump"
        name="Pumps"
        parent="menu_fuel_stations"
        action="action_fuel_pump"
        sequence="20"/>

    <menuitem id="menu_fuel_nozzle"
        name="Nozzles"
        parent="menu_fuel_stations"
        action="action_fuel_nozzle"
        sequence="30"/>

    <menuitem id="menu_fuel_tank"
        name="Tanks"
        parent="menu_fuel_stations"
        action="action_fuel_tank"
        sequence="40"/>

    <!-- Operations -->
    <menuitem id="menu_fuel_operations"
        name="Operations"
        parent="menu_fuel_main"
        sequence="20"/>

    <menuitem id="menu_fuel_shift"
        name="Shifts"
        parent="menu_fuel_operations"
        action="action_fuel_shift"
        sequence="10"/>

    <menuitem id="menu_fuel_meter_reading"
        name="Meter Readings"
        parent="menu_fuel_operations"
        action="action_fuel_meter_reading"
        sequence="20"/>

    <menuitem id="menu_fuel_dip_reading"
        name="Dip Readings"
        parent="menu_fuel_operations"
        action="action_fuel_dip_reading"
        sequence="30"/>

    <!-- Compliance -->
    <menuitem id="menu_fuel_compliance"
        name="Compliance"
        parent="menu_fuel_main"
        sequence="30"/>

    <menuitem id="menu_fuel_license"
        name="Licenses &amp; Permits"
        parent="menu_fuel_compliance"
        action="action_fuel_license"
        sequence="10"/>

    <!-- Configuration -->
    <menuitem id="menu_fuel_config"
        name="Configuration"
        parent="menu_fuel_main"
        sequence="90"
        groups="fuel_management.group_fuel_manager"/>

    <menuitem id="menu_fuel_shift_definition"
        name="Shift Definitions"
        parent="menu_fuel_config"
        action="action_fuel_shift_definition"
        sequence="10"/>

    <menuitem id="menu_fuel_price_wizard"
        name="Update Fuel Prices"
        parent="menu_fuel_config"
        action="action_fuel_price_wizard"
        sequence="20"/>

</odoo>
