<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_fuel_license_form" model="ir.ui.view">
        <field name="name">fuel.license.form</field>
        <field name="model">fuel.license</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="License Name"/></h1>
                    </div>
                    <group>
                        <group string="License Details">
                            <field name="station_id"/>
                            <field name="license_type"/>
                            <field name="license_number"/>
                            <field name="issuing_authority"/>
                        </group>
                        <group string="Validity">
                            <field name="issue_date"/>
                            <field name="expiry_date"/>
                            <field name="days_to_expiry"/>
                            <field name="state" widget="badge"
                                decoration-success="state == 'valid'"
                                decoration-warning="state == 'expiring'"
                                decoration-danger="state == 'expired'"/>
                        </group>
                    </group>
                    <group string="Document">
                        <field name="document" filename="document_name" widget="binary"/>
                        <field name="document_name" invisible="1"/>
                    </group>
                    <field name="notes" placeholder="Notes..."/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_fuel_license_list" model="ir.ui.view">
        <field name="name">fuel.license.list</field>
        <field name="model">fuel.license</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="station_id"/>
                <field name="license_type"/>
                <field name="license_number"/>
                <field name="issuing_authority"/>
                <field name="expiry_date"/>
                <field name="days_to_expiry"/>
                <field name="state" widget="badge"
                    decoration-success="state == 'valid'"
                    decoration-warning="state == 'expiring'"
                    decoration-danger="state == 'expired'"/>
            </list>
        </field>
    </record>

    <record id="view_fuel_license_search" model="ir.ui.view">
        <field name="name">fuel.license.search</field>
        <field name="model">fuel.license</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="station_id"/>
                <field name="license_number"/>
                <filter string="Valid" name="valid" domain="[('state','=','valid')]"/>
                <filter string="Expiring Soon" name="expiring" domain="[('state','=','expiring')]"/>
                <filter string="Expired" name="expired" domain="[('state','=','expired')]"/>
                <group>
                    <filter string="Station" name="group_station" context="{'group_by': 'station_id'}"/>
                    <filter string="License Type" name="group_type" context="{'group_by': 'license_type'}"/>
                    <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_fuel_license" model="ir.actions.act_window">
        <field name="name">Licenses &amp; Compliance</field>
        <field name="res_model">fuel.license</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_fuel_license_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Track your first license</p>
        </field>
    </record>

</odoo>
