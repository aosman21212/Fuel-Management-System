<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_fuel_tank_form" model="ir.ui.view">
        <field name="name">fuel.tank.form</field>
        <field name="model">fuel.tank</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Tank Name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="station_id"/>
                            <field name="product_id"/>
                            <field name="capacity"/>
                            <field name="min_stock_alert"/>
                        </group>
                        <group>
                            <field name="current_stock"/>
                            <field name="state" widget="badge"
                                decoration-success="state == 'normal'"
                                decoration-warning="state == 'low'"
                                decoration-danger="state in ('critical','empty')"/>
                        </group>
                    </group>
                    <field name="notes" placeholder="Notes..."/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_fuel_tank_list" model="ir.ui.view">
        <field name="name">fuel.tank.list</field>
        <field name="model">fuel.tank</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="station_id"/>
                <field name="product_id"/>
                <field name="capacity"/>
                <field name="current_stock"/>
                <field name="min_stock_alert"/>
                <field name="state" widget="badge"
                    decoration-success="state == 'normal'"
                    decoration-warning="state == 'low'"
                    decoration-danger="state in ('critical','empty')"/>
            </list>
        </field>
    </record>

    <record id="action_fuel_tank" model="ir.actions.act_window">
        <field name="name">Tanks</field>
        <field name="res_model">fuel.tank</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Register your first fuel tank</p>
        </field>
    </record>

</odoo>
