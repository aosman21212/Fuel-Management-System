<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_fuel_dip_reading_list" model="ir.ui.view">
        <field name="name">fuel.dip.reading.list</field>
        <field name="model">fuel.dip.reading</field>
        <field name="arch" type="xml">
            <list>
                <field name="shift_id"/>
                <field name="station_id"/>
                <field name="tank_id"/>
                <field name="product_id"/>
                <field name="opening_level"/>
                <field name="received_qty"/>
                <field name="closing_level"/>
                <field name="expected_closing"/>
                <field name="variance"
                    decoration-danger="variance &lt; -10"
                    decoration-warning="variance &lt; 0"
                    decoration-success="variance &gt;= 0"/>
            </list>
        </field>
    </record>

    <record id="action_fuel_dip_reading" model="ir.actions.act_window">
        <field name="name">Dip Readings</field>
        <field name="res_model">fuel.dip.reading</field>
        <field name="view_mode">list</field>
    </record>

</odoo>
